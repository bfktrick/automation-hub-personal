# Application
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# Database
DATABASE_URL=postgresql://admin:admin123@postgres:5432/automation_hub

# Redis
REDIS_URL=redis://redis:6379

# CORS
CORS_ORIGINS=*
CORS_CREDENTIALS=true

# Rate limiting
RATE_LIMIT=100
RATE_TTL=900

# Auth
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=3600

# OpenAI (para integraciones con IA)
OPENAI_API_KEY=

# Telegram (para notificaciones)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# SMTP (para enviar emails)
# Ejemplos:
# Gmail: host=smtp.gmail.com, port=587, user=tu@gmail.com, password=app-specific-password
# SendGrid: host=smtp.sendgrid.net, port=587, user=apikey, password=SG.xxx
# Office365: host=smtp.office365.com, port=587
# Custom: tu servidor SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@automation-hub.local
