// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Automation {
  id          String   @id @default(cuid())
  name        String
  description String?
  isActive    Boolean  @default(true)

  // Trigger configuration as JSON
  // Example trigger: { "type": "cron", "config": { "schedule": "0 8 * * *" } }
  trigger     Json

  // Action configuration as JSON
  // Example action: { "type": "http", "config": { "url": "https://example.com", "method": "POST" } }
  action      Json

  lastRunAt     DateTime?
  lastRunStatus String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  logs ExecutionLog[]

  @@map("automations")
}

model ExecutionLog {
  id             String   @id @default(cuid())
  automationId   String
  automation     Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  status       String   // "running" | "success" | "error"
  startedAt    DateTime @default(now())
  finishedAt   DateTime?
  durationMs   Int?

  // Result or error output
  output       Json?
  error        String?

  // How it was triggered
  triggeredBy  String   // "cron" | "manual" | "webhook"

  createdAt    DateTime @default(now())

  @@index([automationId])
  @@index([createdAt])
  @@map("execution_logs")
}
