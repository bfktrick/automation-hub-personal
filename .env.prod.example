# =============================================================================
# Automation Hub - Variables de Entorno para Producción
# =============================================================================
# Copia este archivo a .env.prod y actualiza los valores antes de desplegar

# ─────────────────────────────────────────────────────────────────────────
# Cloudflare Tunnel (REQUERIDO para acceso remoto)
# ─────────────────────────────────────────────────────────────────────────
# Obtén este token siguiendo los pasos en DEPLOY.prod.md
# Comando: cloudflared tunnel token automation-hub
CLOUDFLARE_TUNNEL_TOKEN=eyJhIjoixxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────────
# Base de Datos PostgreSQL
# ─────────────────────────────────────────────────────────────────────────
# Mínimo 20 caracteres, caracteres especiales recomendados
POSTGRES_PASSWORD=tu_contraseña_super_segura_aqui123!@#

# ─────────────────────────────────────────────────────────────────────────
# Seguridad JWT
# ─────────────────────────────────────────────────────────────────────────
# ⚠️ CRÍTICO: Genera una clave aleatoria fuerte de al menos 32 caracteres
# Comando: openssl rand -base64 32
JWT_SECRET=tu_jwt_secret_aleatorio_y_muy_largo_aqui_123456

# ─────────────────────────────────────────────────────────────────────────
# CORS - URL pública del servidor (con https://, sin trailing slash)
# ─────────────────────────────────────────────────────────────────────────
# Ejemplo: https://automation.tu-dominio.com
CORS_ORIGINS=https://automation.tu-dominio.com

# ─────────────────────────────────────────────────────────────────────────
# Integraciones (Opcional)
# ─────────────────────────────────────────────────────────────────────────
# Deja en blanco si no los usas
OPENAI_API_KEY=sk-...
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_CHAT_ID=123456789

# ─────────────────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────────────────
# Valores: error, warn, info, debug
LOG_LEVEL=info

# =============================================================================
# NOTAS DE SEGURIDAD:
# =============================================================================
# 1. Nunca commitees .env.prod al repositorio (agrégalo a .gitignore)
# 2. Usa credenciales únicas y fuertes
# 3. Rota JWT_SECRET regularmente
# 4. Guarda copias seguras de POSTGRES_PASSWORD en un gestor de secretos
# 5. Usa https:// SIEMPRE en CORS_ORIGINS en producción
# 6. El CLOUDFLARE_TUNNEL_TOKEN es confidencial - protégelo como una contraseña
# 7. Implementa autenticación adicional en Cloudflare (Access Rules)
# 8. Revisa los logs regularmente: docker-compose logs -f
# =============================================================================
